NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
# Optional. Leave blank to auto-detect .venv/bin/python on Linux/macOS or
# .venv/Scripts/python.exe on Windows.
SMART_REFRAME_PYTHON=
# Follow detected subjects throughout each reel. Set false only to restore the
# legacy single crop for an entire clip.
SMART_REFRAME_DYNAMIC=true
FFMPEG_PATH=
FFPROBE_PATH=
APP_URL=http://localhost:3000
CRON_SECRET=
MOCK_TRANSCRIPT_MODE=short
MOCK_AI=false
NEXT_PUBLIC_MOCK_AI=false
MOCK_TRANSCRIPTION=false
MOCK_ANALYSIS=false
ALLOW_MOCK_ANALYSIS_WITH_REAL_TRANSCRIPT=false
ANALYSIS_PROVIDER=auto
LOCAL_ANALYSIS_FALLBACK=true
# Optional. Defaults to ./tmp/analysis-diagnostics. Set an absolute directory
# on a persistent worker host when candidate reports must survive restarts.
ANALYSIS_DIAGNOSTICS_DIR=
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=true

# Phase 1 anonymous source-level diarization. All flags default off so the
# existing production renderer remains unchanged until an allow-listed test.
DIARIZATION_ENABLED=false
DIARIZATION_ALLOW_ALL=false
DIARIZATION_PROJECT_ALLOWLIST=
DIARIZATION_PROVIDER=pyannote
DIARIZATION_PYTHON=
DIARIZATION_SCRIPT=./scripts/diarize_source.py
DIARIZATION_MODEL=pyannote/speaker-diarization-community-1
DIARIZATION_MODEL_REVISION=main
DIARIZATION_EMBEDDING_MODEL=pyannote/wespeaker-voxceleb-resnet34-LM
DIARIZATION_EMBEDDING_MODEL_REVISION=main
DIARIZATION_DEVICE=cpu
DIARIZATION_TIMEOUT_SEC=3600
DIARIZATION_EXTRACT_TIMEOUT_SEC=300
DIARIZATION_FAILURE_MODE=degraded
SPEAKER_EMBEDDING_RETENTION_DAYS=3
# Server-only secrets; never use NEXT_PUBLIC_ prefixes and never commit values.
HF_TOKEN=
ANALYSIS_ARTIFACT_ENCRYPTION_KEY_BASE64=
ANALYSIS_ARTIFACT_ENCRYPTION_KEY_VERSION=v1

# Future reliability phases remain independently disabled.
VOICE_FACE_BINDING_ENABLED=false
IMMUTABLE_RENDER_PLAN_ENABLED=false
POST_RENDER_QA_ENABLED=false

# Transcription provider
TRANSCRIPTION_PROVIDER=openai
FASTER_WHISPER_PYTHON=.venv/bin/python
FASTER_WHISPER_SCRIPT=./scripts/transcribe_faster_whisper.py
FASTER_WHISPER_MODEL=base
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8
WHISPERX_PYTHON=.venv/bin/python
WHISPERX_SCRIPT=./scripts/transcribe_whisperx.py
WHISPERX_MODEL=base
WHISPERX_DEVICE=cpu
WHISPERX_COMPUTE_TYPE=int8

# Optional render tuning (server-safe defaults)
# Keep libx264 for broad compatibility across customer servers.
FFMPEG_VIDEO_ENCODER=libx264
VERTICAL_EXPORT_WIDTH=1080
VERTICAL_EXPORT_HEIGHT=1920
CAPTION_FONTS_DIR=
FFMPEG_EDIT_X264_PRESET=veryfast
FFMPEG_OUTPUT_FPS=0
FFMPEG_X264_PRESET=slow
FFMPEG_X264_CRF=15
FFMPEG_X264_MAXRATE=30M
FFMPEG_X264_BUFSIZE=60M
# If using hardware encoder (e.g. h264_videotoolbox, h264_nvenc), these are used.
FFMPEG_HW_VIDEO_BITRATE=28M
FFMPEG_HW_MAXRATE=36M
FFMPEG_HW_BUFSIZE=72M
# Prefer source pixels over upscaling. Strict 1440p/2160p is attempted before 1080p.
YOUTUBE_MAX_SOURCE_HEIGHT=2160
YOUTUBE_MIN_CACHE_HEIGHT=1440
EXPORT_WORKER_BATCH_SIZE=6

# Auto reframe
AUTO_REFRAME_ENABLED=true
AUTO_REFRAME_MODE=smart

# Optional: comma-separated export IDs to show as public hero showcase reels.
SHOWCASE_EXPORT_IDS=

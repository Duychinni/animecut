{
  "name": "animacut",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "reframe:setup": "node scripts/reframe_runtime.mjs setup",
    "reframe:check": "node scripts/reframe_runtime.mjs check",
    "reframe:regression": "python3 scripts/test_universal_semantic_reframe.py",
    "framing:feedback-report": "node --env-file-if-exists=.env.local scripts/framing-feedback-report.mjs",
    "ffmpeg:args:test": "npx tsx scripts/test_ffmpeg_output_args.ts",
    "worker:deps": "node scripts/reframe_runtime.mjs worker",
    "worker:check": "node scripts/reframe_runtime.mjs check",
    "worker": "npm run worker:check && npx tsx workers/pipelineWorker.ts",
    "worker:once": "npm run worker:check && npx tsx workers/pipelineWorker.ts --once",
    "phase1:check": "python -m unittest scripts/test_phase1_diarization.py && node scripts/validate_phase1_migrations.mjs",
    "previews:backfill": "node --env-file-if-exists=.env.local scripts/backfill-export-previews.mjs",
    "launch:check": "node scripts/launch-readiness.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@sentry/nextjs": "^10.67.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "next": "16.2.0",
    "openai": "^6.32.0",
    "posthog-js": "^1.406.1",
    "posthog-node": "^5.46.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.3.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
